# VERDICT — environment template. Copy to .env (gitignored). NEVER commit real keys.

# --- CoinMarketCap (WP-2, WP-3) ---
# Pro API key from https://pro.coinmarketcap.com  (REST uses this header name)
CMC_PRO_API_KEY=
# MCP key from the same dashboard (MCP uses a DIFFERENT header: X-CMC-MCP-API-KEY)
CMC_MCP_API_KEY=
CMC_MCP_URL=https://mcp.coinmarketcap.com/mcp
CMC_REST_BASE=https://pro-api.coinmarketcap.com

# --- Trust Wallet Agent Kit (WP-4, Track 1) ---
# From https://portal.trustwallet.com  (Access ID + HMAC Secret)
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=

# --- BNB Smart Chain (WP-4, WP-5, Track 1) ---
BSC_MAINNET_RPC=https://bsc-dataseed.bnbchain.org
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.bnbchain.org:8545
BSC_CHAIN_ID=56            # 56 mainnet / 97 testnet
# Agent wallet private key — TESTNET ONLY in dev. Use TWAK keystore for anything real.
AGENT_PRIVATE_KEY=

# --- x402 (optional, keyless CMC pay-per-call on Base) ---
X402_MCP_URL=https://mcp.coinmarketcap.com/x402/mcp
BASE_RPC=https://mainnet.base.org

# --- runtime knobs (WP-5) ---
VERDICT_MODE=paper        # paper | testnet | mainnet
MAX_DRAWDOWN_PCT=25       # hard kill-switch; hackathon DQ example is 30%
DAILY_LOSS_LIMIT_PCT=8
MAX_POSITION_PCT=20
SLIPPAGE_BPS_MAX=80
